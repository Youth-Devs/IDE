rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return true;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isProjectMember(projectId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/projects/$(projectId)) &&
        (
          (
            request.auth != null &&
            get(/databases/$(database)/documents/projects/$(projectId)).data.memberUids != null &&
            request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberUids
          ) ||
          (
            request.auth != null &&
            request.auth.token.email != null &&
            get(/databases/$(database)/documents/projects/$(projectId)).data.memberEmails != null &&
            request.auth.token.email in get(/databases/$(database)/documents/projects/$(projectId)).data.memberEmails
          )
        );
    }

    function isPresenceOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['presence']);
    }

    match /users/{userId} {
      // The IDE queries this collection by email for teammate invites and counts users globally.
      allow read: if isAuthenticated();

      // Users can initialize and update their own profile doc, but only admins can change admin status.
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.isAdmin == false;

      allow update: if isAdmin() || (
        isAuthenticated()
        && request.auth.uid == userId
        // Let self-service updates change usage counters / cooldown state without letting users elevate privileges.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['email', 'isAdmin'])
      );

      allow delete: if isAdmin();
    }

    match /system/{documentId} {
      allow read: if isAuthenticated();

      // Allow the app to bootstrap the hackathon config doc once, but lock ongoing changes to admins.
      allow create: if isAuthenticated()
        && documentId == 'hackathon'
        && !exists(/databases/$(database)/documents/system/hackathon)
        && request.resource.data.active is bool
        && request.resource.data.submissionsEnabled is bool;

      allow update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // Collection queries are used to build the workspace project list. Direct
      // project reads are restricted to the project team or an administrator.
      allow list: if isAuthenticated();
      allow get: if isAdmin() || isProjectMember(projectId);

      allow update: if isAdmin() || (
        isProjectMember(projectId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.slug == resource.data.slug
      ) || (
        // Any project member may submit the team's current project for review,
        // but cannot change unrelated project fields through this permission.
        isProjectMember(projectId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'isHackathonProject',
            'submitted',
            'submittedAt',
            'submittedBy',
            'submittedFiles'
          ])
      ) || (
        isAuthenticated() && isPresenceOnlyUpdate()
      );

      allow delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }

    match /projects/{projectId}/chatMessages/{messageId} {
      allow read: if isAdmin() || isProjectMember(projectId);

      allow create: if isProjectMember(projectId)
        && request.resource.data.role in ['user', 'assistant']
        && request.resource.data.content is string
        && request.resource.data.turnId is string;

      allow update, delete: if isAdmin();
    }

    match /adminSubmissions/{projectId} {
      allow read: if isAdmin() || isProjectMember(projectId);
      // Admins can review and submit legacy projects that do not list their
      // account in memberUids/memberEmails; members remain limited to their
      // own project's submission document.
      allow create, update: if isAdmin() || (
        isProjectMember(projectId) && request.resource.data.projectId == projectId
      );
      allow delete: if isAdmin();
    }
  }
}
